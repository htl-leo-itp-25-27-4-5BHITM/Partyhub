@host = http://localhost:8080
@baseUrl = {{host}}/api/parties
@anna = 1
@michael = 2
@thomas = 4
@mia = 7
@elias = 10

###########################################
### Seed: visible parties for Mia include public + joined/invited
###########################################
GET {{baseUrl}}?user={{mia}}
X-User-Id: {{mia}}

?? status == 200


###########################################
### Seed: public party can be loaded without user
###########################################
GET {{baseUrl}}/1

?? status == 200


###########################################
### Seed: private party is hidden without user context
###########################################
GET {{baseUrl}}/4

?? status == 404


###########################################
### Seed: invited user can load private party 4
###########################################
GET {{baseUrl}}/4?user={{michael}}
X-User-Id: {{michael}}

?? status == 200


###########################################
### Seed: unrelated user cannot load private party 9
###########################################
GET {{baseUrl}}/9?user={{michael}}
X-User-Id: {{michael}}

?? status == 404


###########################################
### Search by title/description
###########################################
GET {{baseUrl}}?q=Afterwork
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter by theme
###########################################
GET {{baseUrl}}?theme=Techno
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter by date range
###########################################
GET {{baseUrl}}?date_from=2026-05-02T00:00:00&date_to=2026-05-04T23:59:59
X-User-Id: {{anna}}

?? status == 200


###########################################
### Sort by start date ascending
###########################################
GET {{baseUrl}}?sort=asc
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Within 2 weeks from now
###########################################
GET {{baseUrl}}?user_age=25
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Free parties within 2 weeks
###########################################
GET {{baseUrl}}?free_only=true
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Techno theme
###########################################
GET {{baseUrl}}?theme=Techno
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Age 25, Free parties, Techno theme
###########################################
GET {{baseUrl}}?user_age=25&free_only=true&theme=Techno
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Age restricted 30+ parties
###########################################
GET {{baseUrl}}?user_age=35
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Teen parties (13-19 age range)
###########################################
GET {{baseUrl}}?user_age=16
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Text search for "Jazz"
###########################################
GET {{baseUrl}}?q=Jazz
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Text search for "Electronic"
###########################################
GET {{baseUrl}}?q=Electronic
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Text search + free parties
###########################################
GET {{baseUrl}}?q=Festival&free_only=true
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Distance based (5km from user location)
### User 1 location: 14.251920, 48.268335 (Leonding)
###########################################
GET {{baseUrl}}?user_latitude=14.251920&user_longitude=48.268335&distance=5
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Distance 10km from main square
### Hauptplatz: 14.2850, 48.3065
###########################################
GET {{baseUrl}}?user_latitude=14.2850&user_longitude=48.3065&distance=10
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: All 6 filters combined
### Age 20, free, House theme, within 5km from Hauptplatz
###########################################
GET {{baseUrl}}?user_age=20&free_only=true&theme=House&user_latitude=14.2850&user_longitude=48.3065&distance=5
X-User-Id: {{anna}}

?? status == 200


###########################################
### Filter: Invalid - missing longitude
###########################################
GET {{baseUrl}}?user_latitude=14.2850
X-User-Id: {{anna}}

?? status == 400


###########################################
### Filter: Invalid - negative distance
###########################################
GET {{baseUrl}}?user_latitude=14.2850&user_longitude=48.3065&distance=-5
X-User-Id: {{anna}}

?? status == 400

