@searchName = anna
@searchResultId = 1

###
GET http://localhost:8080/api/users/all

?? status == 200

### Search users by name
# @name searchUsersByName
GET http://localhost:8080/api/users/all/search?name={{searchName}}

?? status == 200

###
GET http://localhost:8080/api/users/{{searchResultId}}

?? status == 200
### User direkt per ID holen
GET http://localhost:8080/api/users/1
?? status == 200

