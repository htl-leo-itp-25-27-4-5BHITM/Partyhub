@host = http://localhost:8080
@baseUrl = {{host}}/api/qr

###########################################
### Generate QR payload for Anna
###########################################
GET {{baseUrl}}/generate?userId=1
X-User-Id: 1

?? status == 200


###########################################
### Generate QR needs userId
###########################################
GET {{baseUrl}}/generate
X-User-Id: 1

?? status == 200


###########################################
### Generate QR for unknown user
###########################################
GET {{baseUrl}}/generate?userId=99999
X-User-Id: 1

?? status == 200


###########################################
### Unknown QR token status
###########################################
GET {{baseUrl}}/status/does-not-exist

?? status == 404


###########################################
### QR image by user
###########################################
GET {{baseUrl}}/image/user/1

?? status == 200


###########################################
### QR image by unknown user
###########################################
GET {{baseUrl}}/image/user/99999

?? status == 404


###########################################
### QR image by unknown token
###########################################
GET {{baseUrl}}/image/does-not-exist

?? status == 404


###########################################
### Exchange needs token
###########################################
POST {{baseUrl}}/exchange
Content-Type: application/json

{}

?? status == 400


###########################################
### Exchange rejects unknown token
###########################################
POST {{baseUrl}}/exchange
Content-Type: application/json

{
  "token": "does-not-exist"
}

?? status == 404
