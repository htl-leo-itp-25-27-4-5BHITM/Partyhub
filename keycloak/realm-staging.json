{
  "realm": "partyhub",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "verifyEmail": true,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "requiredActions": [
    {
      "alias": "VERIFY_EMAIL",
      "name": "Verify Email",
      "providerId": "VERIFY_EMAIL",
      "enabled": true,
      "defaultAction": true,
      "priority": 0
    }
  ],
  "smtpServer": {
    "host": "smtp.gmail.com",
    "port": "587",
    "from": "noreply.partyhub@gmail.com",
    "fromDisplayName": "PartyHub",
    "replyTo": "noreply.partyhub@gmail.com",
    "auth": "true",
    "starttls": "true",
    "user": "noreply.partyhub@gmail.com",
    "password": "${SMTP_PASSWORD}"
  },
  "roles": {
    "realm": [
      {
        "name": "admin"
      }
    ]
  },
  "clients": [
    {
      "clientId": "frontend",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:8080/*",
        "https://it220274.cloud.htl-leonding.ac.at/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "https://it220274.cloud.htl-leonding.ac.at"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "backend-test",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": false,
      "secret": "test-client-secret",
      "serviceAccountsEnabled": true,
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "partyhub-ios",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "directAccessGrantsEnabled": false,
      "standardFlowEnabled": true,
      "redirectUris": [
        "partyhub.auth://callback",
        "partyhub.auth://callback/*"
      ],
      "webOrigins": [],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "partyhub.auth://callback"
      }
    }
  ],
